---
const { title = 'Sean Morse — Design Director' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Sean Morse — Design Director. Strategic brand development and packaging design for CPG brands." />
  <title>{title}</title>

  <!-- Google Fonts: Cormorant Garamond + DM Sans -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap"
    rel="stylesheet"
  />

  <!-- Global Styles -->
  <style is:global>
    @import '../styles/global.css';
  </style>
</head>
<body>
  <slot />

  <!-- Scripts -->
  <script is:inline src="/scripts/router.js"></script>
  <script is:inline src="/scripts/animations.js"></script>
</body>
</html>
