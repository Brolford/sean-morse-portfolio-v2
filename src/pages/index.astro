---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StatBar from '../components/StatBar.astro';
import BrandMarquee from '../components/BrandMarquee.astro';
import SpotlightHero from '../components/SpotlightHero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import DisciplineTicker from '../components/DisciplineTicker.astro';
import ContactModal from '../components/ContactModal.astro';
import StickerBadge from '../components/StickerBadge.astro';
import AccoladeBar from '../components/AccoladeBar.astro';
import { projects, heroShowcaseImages } from '../data/projects.js';

/* Map projects by slug for grid layout */
const bySlug = Object.fromEntries(projects.map(p => [p.slug, p]));

/* Serialize hero images for the JS showcase script */
const heroImagesJson = JSON.stringify(heroShowcaseImages);
---
<Base>
  <Nav />

  <!-- HERO — Immersive showcase with cycling work + cursor trail -->
  <section class="hero-section relative overflow-hidden" style="min-height: 100vh; display: flex; align-items: center;">

    <!-- Auto-cycling project images (Ken Burns effect) -->
    <div id="hero-showcase-bg" class="hero-showcase-bg" data-hero-images={heroImagesJson}></div>

    <!-- Overlay — warm cream wash for text legibility -->
    <div class="hero-showcase-overlay"></div>

    <!-- Hero content — text on top of everything -->
    <div class="hero-content w-full" style="padding: 0 var(--space-fluid);">
      <div class="mx-auto" style="max-width: 1400px;">

        <!-- Overline -->
        <div class="flex items-center mb-6">
          <span class="hero-rule inline-block mr-3" style="width: 32px; height: 1px; background: var(--color-muted); transition: transform 600ms var(--ease-out);"></span>
          <span class="hero-animate" style="font-family: var(--font-body); font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-muted); transition: opacity 400ms var(--ease-out), transform 400ms var(--ease-out); transition-delay: 150ms;">
            Design Director — Portland, OR
          </span>
        </div>

        <!-- Headline — cinematic blur reveal, centered weight -->
        <h1 class="mb-4" style="max-width: 900px;">
          <span class="hero-blur-reveal block" style="font-family: var(--font-display); font-weight: 300; font-size: var(--text-display-xl); line-height: 1.0; letter-spacing: -0.02em; color: var(--color-text); transition-delay: 200ms;">Strategic Design</span>
          <span class="hero-blur-reveal block" style="font-family: var(--font-display); font-weight: 300; font-size: var(--text-display-xl); line-height: 1.0; letter-spacing: -0.02em; color: var(--color-text); transition-delay: 400ms;">Meets Visible</span>
          <span class="hero-blur-reveal block" style="font-family: var(--font-display); font-weight: 300; font-size: var(--text-display-xl); line-height: 1.0; letter-spacing: -0.02em; transition-delay: 600ms;"><span style="color: var(--color-accent);">Impact.</span></span>
        </h1>

        <!-- Descriptor -->
        <p class="hero-animate" style="font-family: var(--font-body); font-weight: 300; font-size: 17px; color: var(--color-muted); max-width: 480px; margin-top: 16px; transition: opacity 400ms var(--ease-out), transform 400ms var(--ease-out); transition-delay: 460ms;">
          Brand development and packaging design for CPG brands that take their craft seriously.
        </p>

        <!-- Scroll hint -->
        <div class="hero-animate" style="margin-top: 48px; transition: opacity 400ms var(--ease-out), transform 400ms var(--ease-out); transition-delay: 800ms;">
          <span style="font-family: var(--font-body); font-size: 10px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-muted); opacity: 0.6;">Scroll to explore ↓</span>
        </div>

      </div>
    </div>
  </section>

  <!-- STATS BAR -->
  <StatBar />

  <!-- BRAND MARQUEE -->
  <BrandMarquee />

  <!-- SPOTLIGHT -->
  <SpotlightHero />

  <!-- PROJECT GRID -->
  <section class="py-16" style="padding-left: var(--space-fluid); padding-right: var(--space-fluid);">
    <div class="mx-auto" style="max-width: 1400px;">
      <h2 class="animate-up mb-6" style="font-family: var(--font-body); font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-muted);">Selected Work</h2>

      <!-- Main grid — using animate-up-rich for cinematic stagger -->
      <!-- Row: Full-width hero card -->
      <div class="relative animate-up-rich mb-3" data-delay="1" style="height: 500px;">
        <ProjectCard project={bySlug['liquid-iv']} cardClass="w-full h-full" />
        {bySlug['liquid-iv'].stickerNumber && (
          <StickerBadge
            edgeText={bySlug['liquid-iv'].stickerEdge || bySlug['liquid-iv'].title}
            statNumber={bySlug['liquid-iv'].stickerNumber}
            statLabel={bySlug['liquid-iv'].stickerLabel || ''}
            size={140}
          />
        )}
      </div>

      <!-- Row: Big left, small right (3fr / 2fr) -->
      <div class="grid grid-cols-1 md:grid-cols-[3fr_2fr] gap-3 mb-3">
        <div class="animate-up-rich" data-delay="1" style="height: 440px;">
          <ProjectCard project={bySlug['leisure-project']} cardClass="w-full h-full" />
        </div>
        <div class="animate-up-rich" data-delay="2" style="height: 440px;">
          <ProjectCard project={bySlug['alecs-ice-cream']} cardClass="w-full h-full" />
        </div>
      </div>

      <!-- ACCOLADE: Liquid I.V. acquisition -->
      <AccoladeBar
        stat="$320M+"
        label="Revenue influenced — Liquid I.V. acquired by Unilever"
        detail="Brand & packaging redesign positioned the category leader for acquisition"
        image="https://images.squarespace-cdn.com/content/v1/57acaaf46a4963c5935b4584/0c0ae01d-58e0-4fb2-b5c8-e439ea8cac3a/Leisure_CaseStudy_OC_Can.jpg"
        imagePosition="right"
      />

      <!-- Row: Small left, big right (2fr / 3fr) — flipped -->
      <div class="grid grid-cols-1 md:grid-cols-[2fr_3fr] gap-3 mb-3">
        <div class="animate-up-rich" data-delay="1" style="height: 380px;">
          <ProjectCard project={bySlug['elenita-mezcal']} cardClass="w-full h-full" />
        </div>
        <div class="animate-up-rich" data-delay="2" style="height: 380px;">
          <ProjectCard project={bySlug['v8']} cardClass="w-full h-full" />
        </div>
      </div>

      <!-- ACCOLADE: Awards -->
      <AccoladeBar
        stat="#1"
        label="Dieline Award — Dairy Category, 2023"
        detail="Alec's Ice Cream · 7× distribution increase · National Whole Foods placement"
        image="https://images.squarespace-cdn.com/content/v1/57acaaf46a4963c5935b4584/56dd264f-f6d4-49be-8d39-d648ce778745/Alec%27s_1st_Place.jpg"
        imagePosition="left"
      />

      <!-- Lower grid -->
      <div class="mt-3 grid grid-cols-1 sm:grid-cols-3 gap-3">
        <div class="animate-up-rich" data-delay="1" style="height: 380px;">
          <ProjectCard project={bySlug['over-easy']} cardClass="w-full h-full" />
        </div>
        <div class="animate-up-rich" data-delay="2" style="height: 380px;">
          <ProjectCard project={bySlug['mimio']} cardClass="w-full h-full" />
        </div>
        <div class="animate-up-rich" data-delay="3" style="height: 380px;">
          <ProjectCard project={bySlug['picture-day']} cardClass="w-full h-full" />
        </div>
      </div>
    </div>
  </section>

  <!-- DISCIPLINE TICKER -->
  <DisciplineTicker />

  <!-- WORK CTA — with cursor-following accent glow -->
  <section class="w-full cursor-glow-section" style="background: var(--color-block); padding: 96px 24px;">
    <div class="mx-auto text-center" style="max-width: 600px;">
      <h2 class="animate-up" style="font-family: var(--font-display); font-weight: 300; font-style: italic; font-size: clamp(28px,3.5vw,48px); color: white; line-height: 1.2;">
        Sean partners with brands that take their craft seriously.
      </h2>
      <button class="animate-up mt-10 work-cta-btn transition-all duration-250 cursor-pointer" data-delay="1" style="border: 1px solid rgba(255,255,255,0.4); color: white; padding: 14px 40px; border-radius: 2px; font-family: var(--font-body); font-size: 12px; text-transform: uppercase; letter-spacing: 0.1em; background: transparent;" onclick="if(typeof openContactModal==='function')openContactModal()">
        Get in touch
      </button>
    </div>
  </section>

  <Footer />
  <ContactModal />
</Base>
