---
/**
 * AwardsBar — horizontal row of award/impact badges for project detail pages.
 * Each award is a pill with a large stat and small label.
 * Placeholder for future Recraft-generated icons.
 */
const { awards = [] } = Astro.props;
---

{awards.length > 0 && (
  <div class="awards-bar animate-up" style="margin: 40px 0; padding: 32px 0; border-top: 1px solid var(--color-divider); border-bottom: 1px solid var(--color-divider);">
    <span style="font-family: var(--font-body); font-size: 10px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-accent); display: block; margin-bottom: 20px;">Impact & Recognition</span>
    <div class="flex flex-wrap gap-3">
      {awards.map(award => (
        <div class="award-pill" style="display: flex; align-items: center; gap: 12px; padding: 14px 20px; border-radius: 6px; background: var(--color-block); min-width: 140px;">
          <span style="font-family: var(--font-display); font-weight: 300; font-style: italic; font-size: 24px; color: var(--color-accent); white-space: nowrap;">
            {award.stat}
          </span>
          <span style="font-family: var(--font-body); font-weight: 300; font-size: 12px; color: rgba(255,255,255,0.6); line-height: 1.3;">
            {award.label}
          </span>
        </div>
      ))}
    </div>
  </div>
)}
