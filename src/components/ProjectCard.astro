---
const { project, cardClass } = Astro.props;
const isComingSoon = project.comingSoon;
---
<!-- Single project card with gradient, overlay, and hover states -->
<div
  class={`project-card group relative overflow-hidden rounded ${cardClass} ${isComingSoon ? 'cursor-default' : 'cursor-pointer'}`}
  data-slug={project.slug}
  data-case-study={project.caseStudy}
  data-coming-soon={isComingSoon || false}
>
  <!-- Gradient background -->
  <div class={`project-card-bg w-full h-full transition-transform duration-400 ${project.gradientClass}`}
    style="transition-timing-function: var(--ease-out);"></div>

  <!-- Overlay (always visible) -->
  <div class="absolute inset-0" style={`background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 55%);${isComingSoon ? 'opacity: 0.5;' : ''}`}>
    <!-- Bottom-left info stack -->
    <div class="absolute bottom-5 left-5 right-5">
      <!-- Descriptor (shows on hover, positioned above the title) -->
      {!isComingSoon && project.descriptor && (
        <div class="project-descriptor opacity-0 translate-y-2 transition-all duration-300 mb-2" style="font-family: var(--font-display); font-weight: 300; font-style: italic; font-size: 15px; color: rgba(255,255,255,0.8);">
          {project.descriptor}
        </div>
      )}
      <div style="font-family: var(--font-body); font-size: 10px; text-transform: uppercase; letter-spacing: 0.12em; color: rgba(255,255,255,0.75);">
        {project.category}
      </div>
      <div style="font-family: var(--font-display); font-weight: 300; font-style: italic; font-size: clamp(22px,2.5vw,40px); color: white; line-height: 1.15;">
        {project.title}
      </div>
      <div style="font-family: var(--font-body); font-size: 10px; text-transform: uppercase; letter-spacing: 0.12em; color: rgba(255,255,255,0.75); margin-top: 2px;">
        {project.year}
      </div>
    </div>
  </div>
</div>

<style>
  .project-card:not([data-coming-soon="true"]):hover {
    transform: scale(1.02);
    transition: transform 400ms var(--ease-out);
  }
  .project-card:not([data-coming-soon="true"]):hover .project-card-bg {
    transform: scale(1.04);
  }
  .project-card:not([data-coming-soon="true"]):hover .project-descriptor {
    opacity: 1;
    transform: translateY(0);
  }
</style>
