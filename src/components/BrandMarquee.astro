<!-- Two-row brand marquee — pure CSS, no JS -->
<section class="marquee-mask overflow-hidden" style="background: var(--color-bg); border-top: 1px solid var(--color-divider); border-bottom: 1px solid var(--color-divider); padding: 36px 0;" aria-hidden="true">
  <!-- Row 1 — scrolls left -->
  <div class="flex items-center h-8 whitespace-nowrap overflow-hidden mb-2">
