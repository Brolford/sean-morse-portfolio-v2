    </div>
  </div>
  <!-- Row 2 — scrolls right -->
  <div class="flex items-center h-8 whitespace-nowrap overflow-hidden">
    <div class="brand-marquee-track flex items-center" style="animation: scroll-right 35s linear infinite; will-change: transform; font-family: var(--font-display); font-weight: 300; font-size: clamp(11px, 1.3vw, 14px); letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-muted);">
      <span class="px-3">Picture Day · SmartyPants · Alec's Ice Cream · Mimio · Leisure Project · V8 · Over Easy · Elenita Mezcal · Liquid I.V. · Dream Pops · Joolies · Gimme</span>
