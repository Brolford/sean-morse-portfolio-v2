---
/**
 * ProjectCollage — renders one of 5 image/gradient grid layouts.
 * Uses real images when available, gradient placeholders as fallback.
 */
const { layout = 'A', gradientClass = '', images = [] } = Astro.props;
const g = gradientClass;

/* Helper: render an image slot — real image if available, gradient fallback */
function img(index) {
  return images[index] || null;
}
---

{/* Layout A: Wide hero + 3-column strip (4 slots) */}
{layout === 'A' && (
  <div class="flex flex-col gap-3">
    <div class="rounded overflow-hidden" style="width:100%;aspect-ratio:2.4/1;">
      {img(0) ? <img src={img(0)} alt="" class="w-full h-full" style="object-fit:cover;" loading="lazy" /> : <div class={`${g} w-full h-full`}></div>}
    </div>
    <div class="collage-grid" style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
      <div class="rounded overflow-hidden" style="aspect-ratio:3/4;">
        {img(1) ? <img src={img(1)} alt="" class="w-full h-full" style="object-fit:cover;" loading="lazy" /> : <div class={`${g} w-full h-full`} style="opacity:0.85;"></div>}
      </div>
      <div class="rounded overflow-hidden" style="aspect-ratio:3/4;">
        {img(2) ? <img src={img(2)} alt="" class="w-full h-full" style="object-fit:cover;" loading="lazy" /> : <div class={`${g} w-full h-full`} style="opacity:0.7;"></div>}
      </div>
      <div class="rounded overflow-hidden" style="aspect-ratio:3/4;">
        {img(3) ? <img src={img(3)} alt="" class="w-full h-full" style="object-fit:cover;" loading="lazy" /> : <div class={`${g} w-full h-full`} style="opacity:0.55;"></div>}
      </div>
    </div>
  </div>
)}

{/* Layout B: Asymmetric 2-col + tall sidebar (3 slots) */}
{layout === 'B' && (
  <div class="collage-grid" style="display:grid;grid-template-columns:1.6fr 1fr;grid-template-rows:3fr 1fr;gap:12px;min-height:500px;">
    <div class="rounded overflow-hidden" style="grid-row:1/2;">
      {img(0) ? <img src={img(0)} alt="" class="w-full h-full" style="object-fit:cover;" loading="lazy" /> : <div class={`${g} w-full h-full`}></div>}
    </div>
    <div class="rounded overflow-hidden" style="grid-row:1/3;">
      {img(2) ? <img src={img(2)} alt="" class="w-full h-full" style="object-fit:cover;" loading="lazy" /> : <div class={`${g} w-full h-full`} style="opacity:0.85;"></div>}
    </div>
    <div class="rounded overflow-hidden" style="grid-row:2/3;">
      {img(1) ? <img src={img(1)} alt="" class="w-full h-full" style="object-fit:cover;" loading="lazy" /> : <div class={`${g} w-full h-full`} style="opacity:0.7;"></div>}
    </div>
  </div>
)}

{/* Layout C: Stacked hero + 2 offset squares (3 slots) */}
{layout === 'C' && (
  <div class="flex flex-col gap-3">
    <div class="rounded overflow-hidden" style="width:100%;aspect-ratio:16/7;">
      {img(0) ? <img src={img(0)} alt="" class="w-full h-full" style="object-fit:cover;" loading="lazy" /> : <div class={`${g} w-full h-full`}></div>}
    </div>
    <div class="collage-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
      <div class="rounded overflow-hidden" style="aspect-ratio:1/1;">
        {img(1) ? <img src={img(1)} alt="" class="w-full h-full" style="object-fit:cover;" loading="lazy" /> : <div class={`${g} w-full h-full`} style="opacity:0.8;"></div>}
      </div>
      <div class="rounded overflow-hidden" style="aspect-ratio:1/1;">
        {img(2) ? <img src={img(2)} alt="" class="w-full h-full" style="object-fit:cover;" loading="lazy" /> : <div class={`${g} w-full h-full`} style="opacity:0.6;"></div>}
      </div>
    </div>
  </div>
)}

{/* Layout D: Mosaic — tall left + stacked right (4 slots) */}
{layout === 'D' && (
  <div class="collage-grid" style="display:grid;grid-template-columns:1fr 1.4fr;gap:12px;grid-template-rows:1fr 1fr;">
    <div class="rounded overflow-hidden" style="grid-row:1/3;min-height:400px;">
      {img(0) ? <img src={img(0)} alt="" class="w-full h-full" style="object-fit:cover;" loading="lazy" /> : <div class={`${g} w-full h-full`}></div>}
    </div>
    <div class="rounded overflow-hidden" style="min-height:0;">
      {img(1) ? <img src={img(1)} alt="" class="w-full h-full" style="object-fit:cover;" loading="lazy" /> : <div class={`${g} w-full h-full`} style="opacity:0.85;"></div>}
    </div>
    <div class="collage-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:12px;min-height:0;">
      <div class="rounded overflow-hidden">
        {img(2) ? <img src={img(2)} alt="" class="w-full h-full" style="object-fit:cover;" loading="lazy" /> : <div class={`${g} w-full h-full`} style="opacity:0.7;"></div>}
      </div>
      <div class="rounded overflow-hidden">
        {img(3) ? <img src={img(3)} alt="" class="w-full h-full" style="object-fit:cover;" loading="lazy" /> : <div class={`${g} w-full h-full`} style="opacity:0.55;"></div>}
      </div>
    </div>
  </div>
)}

{/* Layout E: Full bleed + narrow strip + wide (3 slots) */}
{layout === 'E' && (
  <div class="flex flex-col gap-3">
    <div class="rounded overflow-hidden" style="width:100%;aspect-ratio:21/9;">
      {img(0) ? <img src={img(0)} alt="" class="w-full h-full" style="object-fit:cover;" loading="lazy" /> : <div class={`${g} w-full h-full`}></div>}
    </div>
    <div class="collage-grid" style="display:grid;grid-template-columns:2fr 1fr;gap:12px;">
      <div class="rounded overflow-hidden" style="aspect-ratio:2/1;">
        {img(1) ? <img src={img(1)} alt="" class="w-full h-full" style="object-fit:cover;" loading="lazy" /> : <div class={`${g} w-full h-full`} style="opacity:0.8;"></div>}
      </div>
      <div class="rounded overflow-hidden" style="aspect-ratio:1/1;">
        {img(2) ? <img src={img(2)} alt="" class="w-full h-full" style="object-fit:cover;" loading="lazy" /> : <div class={`${g} w-full h-full`} style="opacity:0.65;"></div>}
      </div>
    </div>
  </div>
)}
