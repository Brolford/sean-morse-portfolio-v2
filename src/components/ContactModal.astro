<!-- Contact modal — overlay + slide-up panel, mailto submit -->
<div id="contact-overlay" class="fixed inset-0 z-[300] opacity-0 pointer-events-none transition-opacity duration-200" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);">
</div>

<div id="contact-panel" class="fixed z-[301] transition-transform duration-350" style="background: var(--color-bg); transform: translateY(100%); transition-timing-function: var(--ease-out); bottom: 0; left: 0; right: 0; border-radius: 12px 12px 0 0; padding: 48px; max-height: 90vh; overflow-y: auto;">
  <!-- Close button -->
  <button id="contact-close" class="absolute top-5 right-5 bg-transparent border-none cursor-pointer transition-colors duration-200" style="font-family: var(--font-body); font-size: 20px; color: var(--color-muted);" aria-label="Close contact form">×</button>

  <!-- Headline -->
  <h2 style="font-family: var(--font-display); font-weight: 300; font-style: italic; font-size: 36px; color: var(--color-text); margin-bottom: 8px;">Get in touch.</h2>
  <p style="font-family: var(--font-body); font-size: 14px; color: var(--color-muted); margin-bottom: 32px;">Have a project in mind? Fill this out and it'll open in your email, ready to send.</p>

  <!-- Form -->
  <form id="contact-form" class="flex flex-col gap-6">
    <div>
      <label style="font-family: var(--font-body); font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-muted); margin-bottom: 4px; display: block;">Name</label>
      <input type="text" name="name" required style="border: none; border-bottom: 1px solid var(--color-divider); background: transparent; padding: 12px 0; font-family: var(--font-body); font-size: 15px; width: 100%; outline: none; color: var(--color-text);" />
    </div>
    <div>
      <label style="font-family: var(--font-body); font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-muted); margin-bottom: 4px; display: block;">Company</label>
      <input type="text" name="company" style="border: none; border-bottom: 1px solid var(--color-divider); background: transparent; padding: 12px 0; font-family: var(--font-body); font-size: 15px; width: 100%; outline: none; color: var(--color-text);" />
    </div>
    <div>
      <label style="font-family: var(--font-body); font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-muted); margin-bottom: 4px; display: block;">Email</label>
      <input type="email" name="email" required style="border: none; border-bottom: 1px solid var(--color-divider); background: transparent; padding: 12px 0; font-family: var(--font-body); font-size: 15px; width: 100%; outline: none; color: var(--color-text);" />
    </div>
    <div>
      <label style="font-family: var(--font-body); font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-muted); margin-bottom: 4px; display: block;">Project Type</label>
      <select name="projectType" required style="border: none; border-bottom: 1px solid var(--color-divider); background: transparent; padding: 12px 0; font-family: var(--font-body); font-size: 15px; width: 100%; outline: none; color: var(--color-text); -webkit-appearance: none; appearance: none;">
        <option value="" disabled selected>Select a project type</option>
        <option value="Brand Identity">Brand Identity</option>
        <option value="Packaging Design">Packaging Design</option>
        <option value="Brand Strategy">Brand Strategy</option>
        <option value="Art Direction">Art Direction</option>
        <option value="Full Brand Development">Full Brand Development</option>
        <option value="Brand Refresh / Evolution">Brand Refresh / Evolution</option>
        <option value="Other">Other</option>
      </select>
    </div>
    <div>
      <label style="font-family: var(--font-body); font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-muted); margin-bottom: 4px; display: block;">Message</label>
      <textarea name="message" rows="4" required style="border: none; border-bottom: 1px solid var(--color-divider); background: transparent; padding: 12px 0; font-family: var(--font-body); font-size: 15px; width: 100%; outline: none; color: var(--color-text); resize: vertical;"></textarea>
    </div>
    <button type="submit" class="self-start transition-colors duration-250 cursor-pointer" style="font-family: var(--font-body); font-size: 13px; text-transform: uppercase; letter-spacing: 0.1em; background: var(--color-text); color: white; padding: 14px 32px; border: none; border-radius: 2px;">
      Send Message
    </button>
  </form>
</div>

<script is:inline>
(function() {
  var overlay = document.getElementById('contact-overlay');
  var panel = document.getElementById('contact-panel');
  var closeBtn = document.getElementById('contact-close');
  var form = document.getElementById('contact-form');

  /* Global open/close functions */
  window.openContactModal = function() {
    overlay.style.pointerEvents = 'auto';
    overlay.style.opacity = '1';
    panel.style.transform = 'translateY(0)';
    document.body.style.overflow = 'hidden';
  };

  window.closeContactModal = function() {
    overlay.style.opacity = '0';
    overlay.style.pointerEvents = 'none';
    panel.style.transform = 'translateY(100%)';
    document.body.style.overflow = '';
  };

  closeBtn.addEventListener('click', window.closeContactModal);
  overlay.addEventListener('click', window.closeContactModal);

  /* Desktop: centered panel */
  function layoutPanel() {
    if (window.innerWidth > 640) {
      panel.style.left = '50%';
      panel.style.right = 'auto';
      panel.style.bottom = '50%';
      panel.style.transform = panel.style.transform === 'translateY(0px)' || panel.style.transform === 'translateY(0)'
        ? 'translate(-50%, 50%)'
        : 'translate(-50%, 100%)';
      panel.style.maxWidth = '520px';
      panel.style.width = '100%';
      panel.style.borderRadius = '8px';
    } else {
      panel.style.left = '0';
      panel.style.right = '0';
      panel.style.bottom = '0';
      panel.style.maxWidth = 'none';
      panel.style.width = 'auto';
      panel.style.borderRadius = '12px 12px 0 0';
      if (panel.style.transform.includes('translate(-50%')) {
        panel.style.transform = 'translateY(0)';
      }
    }
  }

  /* Override open/close for desktop centering */
  var _open = window.openContactModal;
  window.openContactModal = function() {
    overlay.style.pointerEvents = 'auto';
    overlay.style.opacity = '1';
    document.body.style.overflow = 'hidden';
    if (window.innerWidth > 640) {
      panel.style.left = '50%';
      panel.style.right = 'auto';
      panel.style.bottom = '50%';
      panel.style.maxWidth = '520px';
      panel.style.width = '100%';
      panel.style.borderRadius = '8px';
      panel.style.transform = 'translate(-50%, 50%)';
    } else {
      panel.style.left = '0';
      panel.style.right = '0';
      panel.style.bottom = '0';
      panel.style.maxWidth = 'none';
      panel.style.borderRadius = '12px 12px 0 0';
      panel.style.transform = 'translateY(0)';
    }
  };

  window.closeContactModal = function() {
    overlay.style.opacity = '0';
    overlay.style.pointerEvents = 'none';
    document.body.style.overflow = '';
    if (window.innerWidth > 640) {
      panel.style.transform = 'translate(-50%, 100%)';
    } else {
      panel.style.transform = 'translateY(100%)';
    }
  };
  closeBtn.addEventListener('click', window.closeContactModal);
  overlay.addEventListener('click', window.closeContactModal);

  /* Input focus styles */
  var inputs = panel.querySelectorAll('input, select, textarea');
  inputs.forEach(function(input) {
    input.addEventListener('focus', function() {
      this.style.borderBottomColor = 'var(--color-accent)';
    });
    input.addEventListener('blur', function() {
      this.style.borderBottomColor = 'var(--color-divider)';
    });
  });

  /* Submit → mailto */
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var name = form.elements.name.value;
    var company = form.elements.company.value;
    var email = form.elements.email.value;
    var projectType = form.elements.projectType.value;
    var message = form.elements.message.value;

    var subject = encodeURIComponent('Project Inquiry: ' + projectType);
    var body = encodeURIComponent(
      'Name: ' + name + '\n' +
      'Company: ' + company + '\n' +
      'Email: ' + email + '\n' +
      'Project Type: ' + projectType + '\n\n' +
      message
    );

    window.location.href = 'mailto:hello@sfxm.space?subject=' + subject + '&body=' + body;
    window.closeContactModal();
  });

  /* Submit button hover */
  var submitBtn = form.querySelector('button[type="submit"]');
  submitBtn.addEventListener('mouseenter', function() {
    this.style.background = 'var(--color-accent)';
  });
  submitBtn.addEventListener('mouseleave', function() {
    this.style.background = 'var(--color-text)';
  });
})();
</script>
